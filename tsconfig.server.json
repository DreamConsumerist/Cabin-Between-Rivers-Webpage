{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2023"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"types": ["node"],
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"skipLibCheck": true,
		"noEmit": true
	},
	"include": [
		"netlify/**/*.mts",
		"netlify/**/*.ts",
		"db/**/*.ts",
		"lib/**/*.ts",
		"drizzle.config.ts"
	]
}
